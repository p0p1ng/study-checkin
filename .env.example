# ========== 备考打卡系统配置 ==========

# [必填] 学生姓名（显示在页面和 AI 鼓励语中）
STUDENT_NAME=小美

# [必填] 登录密码
# 注意：同时需要修改 index.html 中的 const PASSWORD = 'xxx'

# [可选] AI 鼓励功能（不配置则使用内置鼓励语）
# 支持 OpenAI 兼容 API（如小米 MiMo、OpenAI、DeepSeek 等）
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.xiaomimimo.com/v1/chat/completions
AI_MODEL=mimo-v2-flash

# [可选] 自定义 AI prompt（{name} 会被替换为 STUDENT_NAME）
# AI_PROMPT=你是一个温柔体贴的人，给正在认真备考的{name}一句温暖的鼓励，要甜蜜、有爱，20字以内

# [可选] 应用目录（默认为脚本所在目录）
# APP_DIR=/root/xiaomei-checkin
